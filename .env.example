# Copy this file to .env and paste your Firecrawl API key after the '='.
# Keys look like "fc-...". Get a free key at https://firecrawl.dev
# (free tier ~1000 credits/month). .env is gitignored and the key is never
# printed. Only stage 3 needs this; stages 1, 2, and 4 work without any key.
FIRECRAWL_API_KEY=
